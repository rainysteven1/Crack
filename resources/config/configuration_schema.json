{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Configruation",
  "type": "object",
  "properties": {
    "data path": {
      "type": "object",
      "properties": {
        "data_path": {
          "type": "string"
        },
        "category_list": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "img_dir_list": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "data_path",
        "category_list",
        "img_dir_list"
      ]
    },
    "data attributes": {
      "type": "object",
      "properties": {
        "batch_height": {
          "type": "integer"
        },
        "batch_width": {
          "type": "integer"
        }
      },
      "required": [
        "batch_height",
        "batch_width"
      ]
    },
    "train settings": {
      "type": "object",
      "properties": {
        "batch_size": {
          "type": "integer"
        },
        "N_epochs": {
          "type": "integer"
        },
        "train_split": {
          "type": "integer"
        },
        "criterion": {
          "type": "string",
          "enum": [
            "BCELoss",
            "DiceLoss",
            "BCEDiceLoss",
            "FocalLoss",
            "IoULoss",
            "HybridLoss1"
          ]
        },
        "optimizer": {
          "anyOf": [
            {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string",
                  "const": "Adam"
                },
                "lr": {
                  "type": "number"
                },
                "eps": {
                  "type": "number"
                },
                "amsgrad": {
                  "type": "boolean"
                }
              },
              "required": [
                "name"
              ]
            },
            {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string",
                  "const": "SGD"
                },
                "lr": {
                  "type": "number"
                },
                "momentum": {
                  "type": "number"
                },
                "weight_decay": {
                  "type": "number"
                },
                "nesterov": {
                  "type": "boolean"
                }
              },
              "required": [
                "name"
              ]
            },
            {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string",
                  "const": "AdamW"
                },
                "lr": {
                  "type": "number"
                },
                "weight_decay": {
                  "type": "number"
                }
              },
              "required": [
                "name"
              ]
            }
          ]
        },
        "scheduler": {
          "anyOf": [
            {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string",
                  "const": "LambdaLR"
                },
                "lrf": {
                  "type": "number"
                },
                "lr_lambda": {
                  "type": "string",
                  "enum": [
                    "lr_schedule1",
                    "lr_schedule2",
                    "lr_schedule3"
                  ]
                }
              },
              "required": [
                "name",
                "lr_lambda"
              ]
            },
            {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string",
                  "const": "ReduceLROnPlateau"
                },
                "mode": {
                  "type": "string",
                  "enum": [
                    "max",
                    "min"
                  ]
                },
                "patience": {
                  "type": "integer"
                }
              },
              "required": [
                "name"
              ]
            },
            {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string",
                  "const": "CosineAnnealingLR"
                },
                "T_max": {
                  "type": "integer"
                },
                "eta_min": {
                  "type": "number"
                }
              },
              "required": [
                "name"
              ]
            }
          ]
        },
        "early_stopping_patience": {
          "type": "integer"
        },
        "config": {
          "type": "string",
          "enum": [
            "ViT-B_16",
            "R50-ViT-B_16",
            "ViT-B_32",
            "ViT-L_16",
            "ViT-L_32"
          ]
        }
      },
      "required": [
        "batch_size",
        "N_epochs",
        "train_split",
        "criterion",
        "optimizer",
        "early_stopping_patience"
      ]
    },
    "test settings": {
      "type": "object",
      "properties": {
        "best_last": {
          "type": "string"
        },
        "batch_size": {
          "type": "integer"
        },
        "metrics_mode": {
          "type": "string"
        },
        "config": {
          "type": "string",
          "const": "testing"
        }
      },
      "required": [
        "best_last",
        "batch_size",
        "metrics_mode"
      ]
    },
    "result settings": {
      "type": "object",
      "properties": {
        "folder_list": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "folder_list"
      ]
    }
  },
  "required": [
    "data path",
    "data attributes",
    "train settings",
    "test settings",
    "result settings"
  ]
}